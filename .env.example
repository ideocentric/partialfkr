# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Required to run scripts/distribute.sh (macOS release builds).
# You must be enrolled in the Apple Developer Program to obtain these values.

# Developer ID Application certificate — from Keychain Access or:
#   security find-identity -v -p codesigning
# Format: "Developer ID Application: Your Name (TEAMID)"
CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# App Store Connect API key — from developer.apple.com → Keys
# The .p8 file is downloaded once at creation time; store it safely.
NOTARY_KEY_FILE=/path/to/AuthKey_XXXXXXXXXX.p8
NOTARY_KEY_ID=XXXXXXXXXX
NOTARY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx